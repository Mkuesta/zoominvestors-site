# Directus CMS
NEXT_PUBLIC_DIRECTUS_URL=https://cms.drlogist.com
DIRECTUS_STATIC_TOKEN=your_public_read_token
DIRECTUS_TOKEN=your_admin_write_token

# Site
NEXT_PUBLIC_BASE_URL=https://yoursite.com

# Sitemap (generate once, keep stable)
SITEMAP_SLUG=sm-abc12345.xml

# Stripe (optional)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (optional)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@yoursite.com

# Supabase (optional)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=...
SUPABASE_SERVICE_ROLE_KEY=...

# Preview (optional)
PREVIEW_SECRET=your_preview_secret

# Cron (optional)
CRON_SECRET=your_cron_secret

# Admin (optional)
ADMIN_PASSWORD=your_admin_password
ADMIN_SECRET=your_jwt_secret
